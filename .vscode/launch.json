{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
           // "preLaunchTask": "make", // 调试会话开始前执行的任务，一般为编译程序，c++为g++, c为gcc
            "name": "(gdb) 启动",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/rv_sim.exe",

            "args":["tests/proj_test/output/out.bin"],

            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "internalConsoleOptions":"openOnSessionStart",
            // "externalConsole":true,
            "externalConsole":false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\msys64\\mingw32\\bin\\gdb.exe",//"C:\\mingw\\MinGW\\bin\\gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
    ]
}


